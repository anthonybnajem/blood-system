{
  "name": "lab-system-zgharta",
  "version": "0.1.5",
  "private": true,
  "description": "Blood System desktop and web application",
  "author": "Anthony Najem",
  "repository": {
    "type": "git",
    "url": "https://github.com/anthonybnajem/blood-system.git"
  },
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:setup": "node scripts/setup-sqlite.mjs",
    "db:import:zgharta": "node scripts/import-zgharta-form.mjs",
    "electron:dev": "node scripts/electron-dev.mjs",
    "electron:start": "node scripts/electron-start.mjs",
    "desktop:dev": "npm run electron:dev",
    "desktop:start": "npm run electron:start",
    "desktop:bundle": "npm run build && node scripts/prepare-desktop-bundle.mjs",
    "desktop:dist:win": "npm run desktop:bundle && electron-builder --win nsis --x64 --config electron-builder.json",
    "desktop:dist:win:release": "node scripts/build-desktop-release.mjs --win",
    "desktop:dist:mac": "npm run desktop:bundle && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg zip --arm64 --config electron-builder.json",
    "desktop:dist:mac:release": "node scripts/build-desktop-release.mjs --mac",
    "release:patch": "bash scripts/release-update.sh patch",
    "release:minor": "bash scripts/release-update.sh minor",
    "release:major": "bash scripts/release-update.sh major"
  },
